---
import type { ResourceEntry } from '../lib/getResources';

interface Props {
  resource: ResourceEntry;
  showCategory?: boolean;
}

const { resource, showCategory = false } = Astro.props;
const r = resource.data;

const hostname = new URL(r.url).hostname.replace(/^www\./, '');

const langFlags: Record<string, string> = {
  en: '🇬🇧',
  zh: '🇨🇳',
  ja: '🇯🇵',
  ko: '🇰🇷',
  es: '🇪🇸',
  fr: '🇫🇷',
  de: '🇩🇪',
  pt: '🇵🇹',
  ar: '🇸🇦',
  ru: '🇷🇺',
};

const pricingLabel: Record<string, string> = {
  free: 'Free',
  freemium: 'Freemium',
  paid: 'Paid',
};
---

<a
  href={r.url}
  target="_blank"
  rel="noopener noreferrer nofollow"
  class="group relative flex h-full flex-col gap-3 rounded-2xl border border-ink/[0.08] bg-paper p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-card-hover dark:border-paper/10 dark:bg-paper-panel-dark/60 dark:hover:border-accent/60"
>
  {r.featured && (
    <span class="absolute right-4 top-4 inline-flex items-center gap-1 rounded-full bg-gold/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-gold">
      <span aria-hidden="true">★</span> Featured
    </span>
  )}

  <div class="flex items-start gap-3">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-ink/[0.05] text-base font-semibold text-ink/70 dark:bg-paper/10 dark:text-paper/70">
      {r.favicon ? (
        <img src={r.favicon} alt="" class="h-full w-full object-cover" loading="lazy" />
      ) : (
        <span>{r.name.charAt(0).toUpperCase()}</span>
      )}
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="truncate font-serif text-lg font-semibold leading-tight tracking-tight">
        {r.name}
        <svg class="ml-1 inline h-3 w-3 -translate-y-0.5 text-mute opacity-0 transition-opacity group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" />
        </svg>
      </h3>
      <p class="mt-0.5 truncate text-xs text-mute">{hostname}</p>
    </div>
  </div>

  <p class="line-clamp-3 text-sm leading-relaxed text-ink/75 dark:text-paper/70">
    {r.description}
  </p>

  <div class="mt-auto flex flex-wrap items-center gap-2 pt-1">
    {showCategory && (
      <span class="chip">{r.category}</span>
    )}
    {r.subTags.slice(0, 2).map((tag) => (
      <span class="chip">#{tag}</span>
    ))}
    <span class="chip">{pricingLabel[r.pricing]}</span>
    <span class="ml-auto inline-flex items-center gap-0.5 text-xs">
      {r.languagesSupported.slice(0, 4).map((lang) => (
        <span aria-label={lang} title={lang}>{langFlags[lang] ?? lang}</span>
      ))}
    </span>
  </div>
</a>
