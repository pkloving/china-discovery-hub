---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search"
  description="Search all China Discovery Hub resources."
  noindex
>
  <section class="container-page py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">Search</p>
    <h1 class="mt-3 font-serif text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
      Find what you're after.
    </h1>
    <p class="mt-5 max-w-prose text-lg text-ink/75 dark:text-paper/75">
      Search across every resource, category and editor's pick.
      Try <em>"hsk"</em>, <em>"hanfu"</em>, <em>"visa"</em>, or <em>"deepseek"</em>.
    </p>

    <link
      href="/pagefind/pagefind-ui.css"
      rel="stylesheet"
      onerror="document.getElementById('search-fallback')?.removeAttribute('hidden')"
    />

    <div id="search" class="mt-10"></div>

    <div
      id="search-fallback"
      hidden
      class="mt-10 rounded-2xl border border-dashed border-ink/15 p-10 text-center dark:border-paper/15"
    >
      <p class="font-medium">Search index not built yet.</p>
      <p class="mt-2 text-sm text-mute">
        In development, run <code class="rounded bg-ink/[0.06] px-1.5 py-0.5 font-mono text-xs dark:bg-paper/[0.1]">pnpm build &amp;&amp; pnpm preview</code>
        to generate the Pagefind index, then revisit this page.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      // Inject Pagefind UI script at runtime; defeats Vite's static analyzer
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function () {
        if (!window.PagefindUI) {
          document.getElementById('search-fallback')?.removeAttribute('hidden');
          return;
        }
        new window.PagefindUI({
          element: '#search',
          showImages: false,
          showSubResults: true,
          resetStyles: false,
          excerptLength: 24,
          showEmptyFilters: false,
          translations: {
            placeholder: 'Search resources… (try "pleco" or "visa")',
            clear_search: 'Clear',
            load_more: 'Load more results',
            search_label: 'Search this site',
            filters_label: 'Filter by',
            zero_results: 'No matches for [SEARCH_TERM]',
            many_results: '[COUNT] results for [SEARCH_TERM]',
            one_result: '[COUNT] result for [SEARCH_TERM]',
            alt_search: 'No matches for [SEARCH_TERM]. Showing results for [DIFFERENT_TERM] instead',
            search_suggestion: 'No matches for [SEARCH_TERM]. Try one of the following:',
            searching: 'Searching for [SEARCH_TERM]…'
          }
        });

        // Pre-fill from ?q= and focus
        var params = new URLSearchParams(window.location.search);
        var q = params.get('q');
        var input = document.querySelector('#search input[type="text"]');
        if (input && q) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          setTimeout(function () { input.focus(); }, 100);
        } else if (input) {
          input.focus();
        }
      };
      script.onerror = function () {
        document.getElementById('search-fallback')?.removeAttribute('hidden');
      };
      document.head.appendChild(script);
    })();
  </script>

  <style is:global>
    /* Theme Pagefind UI to match the site design system */
    :root {
      --pagefind-ui-scale: 0.92;
      --pagefind-ui-primary: #9D2933;
      --pagefind-ui-text: #1F2329;
      --pagefind-ui-background: #FAFAF7;
      --pagefind-ui-border: rgba(31, 35, 41, 0.12);
      --pagefind-ui-tag: rgba(31, 35, 41, 0.04);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 14px;
      --pagefind-ui-image-border-radius: 8px;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: 'Inter', system-ui, sans-serif;
    }
    html.dark {
      --pagefind-ui-primary: #B83340;
      --pagefind-ui-text: #FAFAF7;
      --pagefind-ui-background: #24262B;
      --pagefind-ui-border: rgba(250, 250, 247, 0.14);
      --pagefind-ui-tag: rgba(250, 250, 247, 0.06);
    }
    .pagefind-ui__result-title {
      font-family: 'Fraunces', 'Cormorant Garamond', Georgia, serif !important;
      letter-spacing: -0.01em;
    }
    .pagefind-ui__result-title a {
      color: var(--pagefind-ui-text);
    }
    .pagefind-ui__result-title a:hover {
      color: var(--pagefind-ui-primary);
    }
    .pagefind-ui__search-input {
      font-family: 'Inter', system-ui, sans-serif !important;
    }
  </style>
</BaseLayout>
