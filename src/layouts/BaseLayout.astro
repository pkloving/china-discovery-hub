---
import '../styles/globals.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  enableAffiliate?: boolean;
}

const {
  title = 'China Discovery Hub',
  description = 'A curated directory of the best resources to discover China — language, culture, food, travel, business, and beyond.',
  ogImage,
  noindex = false,
  jsonLd,
  enableAffiliate = false,
} = Astro.props;

const jsonLdBlocks = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];

const fullTitle = /china discovery hub/i.test(title)
  ? title
  : `${title} · China Discovery Hub`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://chinahub.cc');

const ogRoute = (() => {
  const stripped = Astro.url.pathname.replace(/^\/+|\/+$/g, '');
  if (!stripped) return 'index';
  if (stripped.startsWith('tag/') || stripped === '404') return 'index';
  return stripped;
})();
const resolvedOgImage = ogImage ?? `/og/${ogRoute}.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="China Discovery Hub — Latest resources"
      href="/rss.xml"
    />

    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={new URL(resolvedOgImage, canonicalURL).toString()} />
    <meta name="twitter:image" content={new URL(resolvedOgImage, canonicalURL).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {jsonLdBlocks.map((block) => (
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(block)}
      />
    ))}

    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('theme');
          var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var useDark = pref === 'dark' || (!pref && systemDark);
          if (useDark) document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1" data-pagefind-body={noindex ? undefined : ''}>
      <slot />
    </main>
    <Footer />
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "cc7929af94b64dd9a8dc30ebd08de9e6"}'
    ></script>
    {import.meta.env.PROD && enableAffiliate && (
      <script
        is:inline
        async
        src="https://s.skimresources.com/js/303361X1791406.skimlinks.js"
      ></script>
    )}
  </body>
</html>
